# HGE CONFIGURATION TEMPLATE
# ==========================
NODE_ENV=production
PORT=3001

# DATABASE PERSISTENCE
MONGO_URI=mongodb://mongodb:27017/hge_db
REDIS_URL=redis://redis:6379

# AUTHENTICATION SECRETS (CHANGE THESE OR RUN init-setup.sh)
JWT_SECRET=HGE-$(openssl rand -hex 32)
JWT_REFRESH_SECRET=HGE-$(openssl rand -hex 32)
SESSION_SECRET=HGE-$(openssl rand -hex 32)

# ACCESS CONTROL
ADMIN_KEY=HGE-ADMIN-9f3a2b1c
INTERNAL_API_KEY=hge_internal_ops_7x9z

# SYSTEM PARAMETERS
FILE_UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=10485760
CORS_ORIGIN=*

# TELEMETRY & LOGGING
DEBUG_MODE=true
VERBOSE_ERRORS=true
